# ya-obs Rust test credentials template
#
# Copy to .env.test (gitignored), fill in real values, then:
#   set -a && source .env.test && set +a
#
# DO NOT commit .env.test. Real credentials only live on your machine.

# --- credentials ------------------------------------------------------------
export HUAWEICLOUD_SDK_AK=""
export HUAWEICLOUD_SDK_SK=""

# --- endpoint ---------------------------------------------------------------
# Full URL including scheme, e.g. https://obsv3.cloud.example.cn
export OBS_ENDPOINT=""

# Region is required for V4 signing even with a custom endpoint.
export OBS_REGION=""

# --- target bucket ----------------------------------------------------------
export OBS_BUCKET=""

# --- TLS (optional) ---------------------------------------------------------
# export SSL_CERT_FILE="/path/to/corp-ca.pem"
# export OBS_INSECURE="1"

# --- signing version (optional, default v4) --------------------------------
export OBS_SIGNING_VERSION="v4"
